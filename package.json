{
  "name": "yuwen",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:web": "pnpm --filter @yuwen/web dev",
    "dev:api": "pnpm --filter @yuwen/api dev",
    "start:web": "pnpm --filter @yuwen/web start",
    "start:api": "pnpm --filter @yuwen/api start",
    "build:web": "pnpm --filter @yuwen/web build",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @yuwen/api prisma:generate",
    "db:migrate": "pnpm --filter @yuwen/api prisma:migrate",
    "db:push": "pnpm --filter @yuwen/api prisma:push"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
